rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128; }

    // --- ENTITY VALIDATIONS ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'plan', 'createdAt', 'lastLogin'])
        && data.keys().size() <= 8
        && data.uid == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.displayName is string && data.displayName.size() <= 128
        && data.plan in ['none', 'starter', 'creator', 'pro', 'enterprise'];
    }

    function isValidUserWrite(data) {
      return isValidUser(data) && data.lastLogin == request.time;
    }

    function isValidUpgrade(data) {
      return data.keys().hasAll(['userId', 'currentPlan', 'requestedPlan', 'transactionId', 'status', 'timestamp'])
        && data.keys().size() == 6
        && data.userId == request.auth.uid
        && data.currentPlan is string
        && data.requestedPlan is string
        && data.transactionId is string && data.transactionId.size() <= 200
        && data.status == 'pending'
        && data.timestamp == request.time;
    }

    // --- COLLECTION RULES ---

    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserWrite(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId)
        && isValidUser(incoming())
        && (incoming().lastLogin == request.time || incoming().lastLogin == existing().lastLogin)
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt;
    }

    // UPGRADE REQUESTS (NEW)
    match /upgrade/{upgradeId} {
      allow get: if isSignedIn() && isValidId(upgradeId) && (resource == null || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(upgradeId) && isValidUpgrade(incoming());
    }

    // LEGACY UPGRADES (Keeping for compatibility if needed, otherwise could remove)
    match /upgrades/{upgradeId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
    }

    match /payments/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}

{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and subscription plan.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "plan": { "type": "string", "enum": ["none", "starter", "creator", "pro", "enterprise"], "description": "The user's current subscription plan." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "plan", "createdAt"]
    },
    "Payment": {
      "title": "Payment Request",
      "description": "Stores a record of a user's request to upgrade their plan.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "plan": { "type": "string", "description": "The plan the user wants to upgrade to." },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"], "description": "The status of the payment request." },
        "time": { "type": "string", "description": "The time the request was made." }
      },
      "required": ["email", "plan", "status", "time"]
    },
    "Upgrade": {
      "title": "Plan Upgrade",
      "description": "Stores a record of a user's plan upgrade request.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who upgraded." },
        "currentPlan": { "type": "string", "description": "The user's current plan." },
        "requestedPlan": { "type": "string", "description": "The plan the user requested." },
        "transactionId": { "type": "string", "description": "The transaction ID provided by the user." },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"], "description": "The status of the upgrade request." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the upgrade occurred." }
      },
      "required": ["userId", "currentPlan", "requestedPlan", "transactionId", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profile documents."
    },
    "/payments/{userId}": {
      "schema": "Payment",
      "description": "Collection of payment request documents."
    },
    "/upgrade/{upgradeId}": {
      "schema": "Upgrade",
      "description": "Collection of plan upgrade documents."
    }
  }
}
